# Copy to .env and fill in real values.
# The install script will generate APP_SECRET_KEY and POSTGRES_PASSWORD if missing.

# Fernet key used to encrypt SMTP password at rest. 32 url-safe base64-encoded bytes.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_SECRET_KEY=

# Postgres credentials
POSTGRES_PASSWORD=

# Host port published by nginx
HOST_PORT=8765
